{
  "name": "rv-lib",
  "version": "0.1.0",
  "description": "Self-contained ES module charting widget for financial candles (RigoView). No runtime dependencies.",
  "type": "module",
  "main": "./rigoview.js",
  "module": "./rigoview.js",
  "exports": {
    ".": {
      "import": "./rigoview.js",
      "default": "./rigoview.js"
    }
  },
  "sideEffects": false,
  "files": ["*.js", "README.md", "CHART-PROVIDER-API.md"],
  "keywords": [
    "chart",
    "candlestick",
    "canvas",
    "financial",
    "trading",
    "websocket",
    "rigoview"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ko0f/rv-lib.git"
  },
  "bugs": {
    "url": "https://github.com/ko0f/rv-lib/issues"
  },
  "homepage": "https://github.com/ko0f/rv-lib#readme"
}
